#include <bits/stdc++.h>
using namespace std;

long long int unique(vector<long long int> &v, long long int n)
{
    sort(v.begin(), v.end());
    long long int count = 1;
    if (n == 0)
    {
        count = 0;
    }
    else
    {
        for (int i = 1; i < n; i++)
        {
            if (v[i] != v[i - 1])
            {
                count++;
            }
        }
        return count;
    }
}

int main()
{
    long long int n;
    cin >> n;

    vector<long long int> v(n);
    for (int i = 0; i < n; i++)
    {
        cin >> v[i];
    }
    cout << unique(v, n);
    return 0;
}
