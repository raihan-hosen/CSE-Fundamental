#include <iostream>
using namespace std;
 
void max_min(long long int x)
{
    long long int arr[x];
    for (int i = 0; i < x; i++)
    {
        cin >> arr[i];
    }
    int max = arr[0], min = arr[0];
 
    for (int i = 1; i < x; i++)
    {
        if (arr[i] > max)
        {
            max = arr[i];
        }
        else if (arr[i] < min)
        {
            min = arr[i];
        }
    }
 
    cout << min << " " << max;
}
 
int main()
{
    long long int x;
    cin >> x;
 
    max_min(x);
    return 0;
}
