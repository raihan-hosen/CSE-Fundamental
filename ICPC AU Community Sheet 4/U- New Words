#include <iostream>
#include <string>
#include <algorithm>

using namespace std;

int main() {
    string s;
    cin >> s;

    long long e = 0, g = 0, y = 0, p = 0, t = 0;

    for (int i = 0; i < s.length(); i++) {
        char c = tolower(s[i]);

        if (c == 'e') e++;
        else if (c == 'g') g++;
        else if (c == 'y') y++;
        else if (c == 'p') p++;
        else if (c == 't') t++;
    }

    long long result = min({e, g, y, p, t});

    cout << result << endl;

    return 0;
}
