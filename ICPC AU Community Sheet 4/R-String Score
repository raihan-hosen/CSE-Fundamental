#include <iostream>
#include <string>
#include <vector>

using namespace std;

int main()
{
    int n;
    cin >> n;

    string s;
    cin >> s;

    vector<char> v;
    for (int i = 0; i < n; i++)
    {
        v.push_back(s[i]);
    }

    long long score = 0;

    for (int i = 0; i < v.size(); i++)
    {
        char current = v[i];

        if (current == 'V')
        {
            score += 5;
        }
        else if (current == 'W')
        {
            score += 2;
        }
        else if (current == 'X')
        {
            if (i + 1 < v.size())
            {
                i++;
            }
        }
        else if (current == 'Y')
        {
            if (i + 1 < v.size())
            {
                char nextChar = v[i + 1];
                v.push_back(nextChar);
                i++;
            }
        }
        else if (current == 'Z')
        {
            if (i + 1 < v.size())
            {
                char nextChar = v[i + 1];
                if (nextChar == 'V')
                {
                    score /= 5;
                    i++;
                }
                else if (nextChar == 'W')
                {
                    score /= 2;
                    i++;
                }
            }
        }
    }

    cout << score << endl;

    return 0;
}
