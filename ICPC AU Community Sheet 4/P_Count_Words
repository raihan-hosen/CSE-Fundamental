#include <iostream>
#include <string>
 
using namespace std;
 
int main() {
    string s;
    getline(cin,s);
 
    int count = 0;
    bool in_word = false;
 
    for (int i = 0; i < s.length(); i++) {
        char c = s[i];
        if ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z')) {
            if (!in_word) {
                count++;
                in_word = true;
            }
        } else {
            in_word = false;
        }
    }
 
    cout << count << endl;
 
    return 0;
}
