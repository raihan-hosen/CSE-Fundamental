#include <iostream>
#include <string>
#include <algorithm>

using namespace std;

int main() {
    string s;
    cin >> s;

    if (s.length() < 2) {
        cout << s << endl;
        return 0;
    }

    string smallest_s = "";

    for (int i = 1; i < s.length(); i++) {
        string x = s.substr(0, i);
        string y = s.substr(i);

        sort(x.begin(), x.end());
        sort(y.begin(), y.end());

        string combined = x + y;

        if (i == 1 || combined < smallest_s) {
            smallest_s = combined;
        }
    }

    cout << smallest_s << endl;

    return 0;
}
