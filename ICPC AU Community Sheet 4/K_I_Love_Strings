#include <iostream>
#include <string>
using namespace std;

int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        string a, b;
        cin >> a >> b;

        int n1 = a.length();
        int n2 = b.length();

        int minLen = (n1 < n2) ? n1 : n2;

        for (int i = 0; i < minLen; i++)
        {
            cout << a[i] << b[i];
        }

        if (n1 > n2)
        {
            for (int i = minLen; i < n1; i++)
            {
                cout << a[i];
            }
        }
        else if (n2 > n1)
        {
            for (int i = minLen; i < n2; i++)
            {
                cout << b[i];
            }
        }

        cout << endl;
    }
    return 0;
}
