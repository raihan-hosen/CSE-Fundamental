#include <iostream>
#include <string>

using namespace std;

int main()
{
    string s;
    cin >> s;

    int pos = s.find('?');
    string params = s.substr(pos + 1);

    string current_param = "";
    for (int i = 0; i < params.length(); i++)
    {
        if (params[i] == '=')
        {
            cout << current_param << ": ";
            current_param = "";
        }
        else if (params[i] == '&')
        {
            cout << current_param << endl;
            current_param = "";
        }
        else
        {
            current_param += params[i];
        }
    }

    cout << current_param << endl;

    return 0;
}
