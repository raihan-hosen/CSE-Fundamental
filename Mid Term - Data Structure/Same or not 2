#include <iostream>
using namespace std;

class Node
{
public:
    int val;
    Node *prev;
    Node *next;

    Node(int v)
    {
        val = v;
        prev = NULL;
        next = NULL;
    }
};

class Stack
{
public:
    Node *top_node;

    Stack()
    {
        top_node = NULL;
    }

    void push(int val)
    {
        Node *new_node = new Node(val);
        if (top_node != NULL)
        {
            top_node->next = new_node;
            new_node->prev = top_node;
        }
        top_node = new_node;
    }

    int pop()
    {
        if (top_node == NULL)
        {
            return -1;
        }

        int val = top_node->val;
        Node *temp = top_node;

        top_node = top_node->prev;
        if (top_node != NULL)
        {
            top_node->next = NULL;
        }

        delete temp;
        return val;
    }
};

class Queue
{
public:
    Node *head;
    Node *tail;

    Queue()
    {
        head = NULL;
        tail = NULL;
    }

    void push(int val)
    {
        Node *new_node = new Node(val);
        if (tail == NULL)
        {
            head = new_node;
            tail = new_node;
        }
        else
        {
            tail->next = new_node;
            new_node->prev = tail;
            tail = new_node;
        }
    }

    int pop()
    {
        if (head == NULL)
        {
            return -1;
        }

        int val = head->val;
        Node *temp = head;

        head = head->next;
        if (head != NULL)
        {
            head->prev = NULL;
        }
        else
        {
            tail = NULL;
        }

        delete temp;
        return val;
    }
};

int main()
{
    int n, m;
    cin >> n >> m;

    Stack st;
    Queue q;

    for (int i = 0; i < n; i++)
    {
        int val;
        cin >> val;
        st.push(val);
    }

    for (int i = 0; i < m; i++)
    {
        int val;
        cin >> val;
        q.push(val);
    }

    if (n != m)
    {
        cout << "NO" << endl;
        return 0;
    }

    bool is_same = true;
    for (int i = 0; i < n; i++)
    {
        int stack_val = st.pop();
        int queue_val = q.pop();

        if (stack_val != queue_val)
        {
            is_same = false;
            break;
        }
    }

    if (is_same)
    {
        cout << "YES" << endl;
    }
    else
    {
        cout << "NO" << endl;
    }

    return 0;
}
