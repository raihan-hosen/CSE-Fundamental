#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int lines = (n + 1) / 2 + 5;
    int stars = 1;
    int spaces = lines - 1;

    for (int i = 1; i <= lines; i++) {
        for (int j = 1; j <= spaces; j++) {
            printf(" ");
        }
        for (int j = 1; j <= stars; j++) {
            printf("*");
        }
        printf("\n");
        stars += 2;
        spaces--;
    }

    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            printf(" ");
        }
        for (int j = 0; j < n; j++) {
            printf("*");
        }
        printf("\n");
    }

    return 0;
}
