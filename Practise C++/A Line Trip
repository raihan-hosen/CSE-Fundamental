#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main()
{
    long long int t;
    cin >> t;
    while (t--)
    {
        long long int n, x;
        cin >> n >> x;

        vector<int> a(n);
        for (int i = 0; i < n; i++)
        {
            cin >> a[i];
        }

        long long int max_gap = a[0] - 0;
        for (int i = 1; i < n; i++)
        {
            max_gap = max<long long>(max_gap, a[i] - a[i - 1]);
        }

        max_gap = max(max_gap, 2 * (x - a[n - 1]));
        cout << max_gap << endl;
    }
    return 0;
}
