#include <iostream>
#include <algorithm>
using namespace std;

int main()
{
    long long int arr[3], original[3];
    for (int i = 0; i < 3; i++)
    {
        cin >> arr[i];
        original[i] = arr[i];
    }

    sort(arr, arr + 3);

    for (int i = 0; i < 3; i++)
        cout << arr[i] << endl;

    cout << "\n";

    for (int i = 0; i < 3; i++)
        cout << original[i] << endl;

    return 0;
}
