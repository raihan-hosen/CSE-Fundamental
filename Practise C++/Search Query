#include <bits/stdc++.h>
using namespace std;

string find(const vector<int> &v, int n, int num)
{
    bool flag = 0;
    for (int i = 0; i < n; i++)
    {
        if (v[i] == num)
        {
            flag = 1;
            break;
        }
        else
            flag = 0;
    }
    if (flag == 1)
        return "YES";
    else
        return "NO";
}

int main()
{
    int n, q;
    if (!(cin >> n))
        return 0;

    vector<int> v(n);
    for (int i = 0; i < n; i++)
    {
        cin >> v[i];
    }
    cin >> q;

    for (int i = 0; i < q; i++)
    {
        int num;
        cin >> num;
        cout << find(v, n, num) << "\n";
    }

    return 0;
}
