#include <bits/stdc++.h>
using namespace std;

void matrixSum(const vector<vector<int>> &A, const vector<vector<int>> &B, int r, int c, int R, int C)
{
    if (r == R)
    {
        return;
    }

    cout << A[r][c] + B[r][c];

    if (c == C - 1)
    {
        cout << "\n";
        matrixSum(A, B, r + 1, 0, R, C);
    }
    else
    {
        cout << " ";
        matrixSum(A, B, r, c + 1, R, C);
    }
}

int main()
{
    int R, C;
    cin >> R >> C;
    {
        vector<vector<int>> A(R, vector<int>(C));
        vector<vector<int>> B(R, vector<int>(C));

        // Read Matrix A
        for (int i = 0; i < R; i++)
        {
            for (int j = 0; j < C; j++)
            {
                cin >> A[i][j];
            }
        }

        // Read Matrix B
        for (int i = 0; i < R; i++)
        {
            for (int j = 0; j < C; j++)
            {
                cin >> B[i][j];
            }
        }

        matrixSum(A, B, 0, 0, R, C);
    }
    return 0;
}

